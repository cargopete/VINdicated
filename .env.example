# VINdicate API environment variables
# Copy to .env and fill in the values

PORT=8080
REDIS_URL=redis://127.0.0.1:6379
RUST_LOG=vindicate_api=info,tower_http=info

# UK — DVLA Vehicle Enquiry Service
# Apply at: https://developer-portal.driver-vehicle-licensing.api.gov.uk/
DVLA_API_KEY=

# UK — DVSA MOT History API (Microsoft Entra OAuth2)
# Apply at: https://documentation.history.mot.api.gov.uk/
DVSA_CLIENT_ID=
DVSA_CLIENT_SECRET=

# Netherlands — RDW Open Data (optional, increases rate limits)
# Register at: https://opendata.rdw.nl/profile/edit/developer_settings
RDW_APP_TOKEN=
